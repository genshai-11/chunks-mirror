{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/tts", "destination": "/api/tts.vercel" },
    { "source": "/api/generate-text", "destination": "/api/generate-text.vercel" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/tts.vercel.ts": { "maxDuration": 30 },
    "api/generate-text.vercel.ts": { "maxDuration": 30 }
  }
}
