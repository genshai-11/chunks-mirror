{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/tts.ts": { "maxDuration": 60 },
    "api/generate-text.ts": { "maxDuration": 300 },
    "api/upload-audio.ts": { "maxDuration": 60 },
    "api/list-audio.ts": { "maxDuration": 30 },
    "api/delete-audio.ts": { "maxDuration": 30 },
    "api/list-models.ts": { "maxDuration": 15 }
  }
}
